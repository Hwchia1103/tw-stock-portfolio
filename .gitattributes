# Set default behavior to automatically handle line endings and force LF on checkout
* text=auto eol=lf

# Force specific file types to keep LF line endings
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
Dockerfile text eol=lf
nginx.conf text eol=lf
